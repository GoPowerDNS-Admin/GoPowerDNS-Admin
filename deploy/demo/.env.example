# Public hostname — TLS is handled by HAProxy, not the app.
DOMAIN=gopowerdns-admin.duckdns.org

# Secrets — generate with:
#   openssl rand -base64 32
#   openssl rand -base64 24
COOKIE_KEY=
ARGON2_SALT=

# PowerDNS connection (optional — leave empty to configure via UI)
PDNS_URL=
PDNS_KEY=
PDNS_VHOST=
