# Public hostname — TLS is handled by HAProxy, not the app.
DOMAIN=gopowerdns-admin.duckdns.org

# Secrets — generate with:
#   openssl rand -base64 32
#   openssl rand -base64 24
#   openssl rand -hex 32
COOKIE_KEY=
ARGON2_SALT=

# PowerDNS API key — shared between the pdns container and the app.
# The app connects to http://pdns:8081 by default (internal compose network).
PDNS_KEY=
