# Domain (DuckDNS or any domain pointing to this server)
DOMAIN=yourname.duckdns.org

# ACME / Let's Encrypt
GPDNS_WEBSERVER_ACMEDOMAIN=yourname.duckdns.org
GPDNS_WEBSERVER_ACMEEMAIL=you@example.com

# Secrets — generate with:
#   openssl rand -base64 32
#   openssl rand -base64 24
COOKIE_KEY=
ARGON2_SALT=

# PowerDNS connection (optional — leave empty to configure via UI)
PDNS_URL=
PDNS_KEY=
PDNS_VHOST=
